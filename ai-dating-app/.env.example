EXPO_PUBLIC_API_BASE_URL=https://your-api-host.example.com/api
EXPO_PUBLIC_DEMO_EMAIL=demo@example.com
EXPO_PUBLIC_DEMO_PASSWORD=Passw0rd!

# Google OAuth client IDs
# Create these in Google Cloud Console (OAuth 2.0 Client IDs).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Optional generic fallback client ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Optional legacy key (still supported in the app code)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
